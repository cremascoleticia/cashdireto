# Copie para .env e preencha. NUNCA commitar .env (está no .gitignore).

# ── Supabase ──
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>                 # front (browser) — sujeito a RLS
SUPABASE_SERVICE_ROLE_KEY=<service-role-key> # APENAS no worker (BYPASSRLS). Nunca no front.

# Postgres direto — usado por migrations e pelo teste de RLS (scripts/run_rls_test.py).
# Pegue em: Supabase > Project Settings > Database > Connection string (URI).
DATABASE_URL=postgres://postgres:<senha>@db.<project-ref>.supabase.co:5432/postgres

# ── Storage ──
STORAGE_BUCKET=fontes

# ── LLM (Fase 5 — provider-agnóstico; preencher só o que for usar) ──
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDERS_PATH=llm/providers.yaml
